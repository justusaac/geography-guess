<!doctype html>
<html>
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Duel lobby</title>
	<style>
		body{
			font-family:sans-serif;
		}
		.rules-form{
			border:1px solid black;
			margin:5px;
			padding:5px;
			line-height:2em;
		}
		.room-content{
			display:flex;
			flex-direction:row;
			flex-wrap:wrap;
		}
		input[readonly]{
			background-color:gray;
		}
		.player-list-container{
			border:1px solid black;
			margin:5px;
			padding:5px;
		}
		.error-container{
			background-color: pink;
			margin: 5px;
			padding: 5px;
		}
		.start-button{
			font-size: 1.5em;
			margin:10px;
		}
		#team_count, #max_player_count{
			width:4em;
		}
	</style>
	<script>
		var global_teams;
		var global_user_info;
		function update_rules(rules){
			for(const suffix of ['','_after_guess']){
				for(const elem of document.getElementsByName('time_limit'+suffix)){
					elem.checked = (rules["time_limit"+suffix] != null);
				}
				for(const elem of [...document.getElementsByName('time_limit_minutes'+suffix), ...document.getElementsByName('time_limit_seconds'+suffix)]){
					elem.readOnly = (rules["time_limit"+suffix] == null);
				}
				if(rules["time_limit"+suffix] != null){
					for(const elem of document.getElementsByName('time_limit_minutes'+suffix)){
						elem.value = Math.floor(rules["time_limit"+suffix]/1000/60)
					}
					for(const elem of document.getElementsByName('time_limit_seconds'+suffix)){
						elem.value = Math.floor(rules["time_limit"+suffix]/1000%60)
					}
				}
			}
			for(const elem of document.getElementsByName('freedom')){
				if(rules.moving){
					elem.value = "moving"
				}
				else if(rules.zooming){
					elem.value = "nm";
				}
				else{
					elem.value = "nmpz";
				}
			}
			for(const elem of document.getElementsByName("max_health")){
				elem.value = rules.max_health;
			}
			for(const elem of document.getElementsByName("public")){
				elem.checked = rules.public;
			}
			for(const elem of document.getElementsByName("max_player_box")){
				elem.checked = (rules.max_players != null)
			}
			for(const elem of document.getElementsByName("max_player_count")){
				if(rules.max_players==null){
					elem.readOnly = true;
				}
				else{
					elem.readOnly = false;
					elem.value = rules.max_players
				}
			}
			if(typeof rules.teams=='object' && rules.teams != null){
				for(const elem of document.getElementsByName("teams")){
					elem.checked = true;
				}
				for(const elem of document.getElementsByName("team_count")){
					elem.readOnly = false;
					elem.value = Object.keys(rules.teams).length;
				}
			}
			else{
				for(const elem of document.getElementsByName("teams")){
					elem.checked = false;
				}
				for(const elem of document.getElementsByName("team_count")){
					elem.readOnly = true;
				}
			}
			global_teams = rules.teams;
			if(global_user_info!=null){
				update_player_list(global_user_info);
			}
		}
		function update_player_list(info){
			global_user_info = info;
			const {owner, users} = info;
			for(const root of document.getElementsByClassName("player-list")){
				root.innerHTML = '';
				for(const user of users){
					const li = document.createElement('li');
					const txt = document.createTextNode('');
					if(document.getElementById("team-box").checked){
						txt.textContent += " ";
						global_teams ??= {}
						const select = document.createElement('select');
						select.classList.add("team-selector");
						select.dataset.user = user
						const unassigned_option = document.createElement('option');
						unassigned_option.value = "";
						unassigned_option.innerHTML = "Unassigned"
						select.appendChild(unassigned_option);
						for(const team in global_teams){
							const option = document.createElement('option');
							option.value = team;
							option.textContent = team;
							select.appendChild(option);
							if(global_teams[team].includes(user)){
								select.value = team;
							}
						}
						li.appendChild(select);
					}
					txt.textContent += user;
					if(user === owner){
						txt.textContent += " (Leader)";
					}
					if(user === "<%= username %>"){
						txt.textContent += " (You)";
					}
					li.appendChild(txt);
					root.appendChild(li);
				}
			}
			
			for(const btn of document.getElementsByClassName("start-button")){
				btn.disabled = (owner != "<%= username %>" || users.length<2);
				btn.style.visibility = (owner != "<%= username %>") ? "hidden" : "visible";

			}
			for(const tag of ["input","select"]){
				for(const elem of document.getElementById("rules-form").getElementsByTagName(tag)){
					elem.disabled = (owner != "<%= username %>")
				}
			}

		}
		function show_error(err){
			for(const elem of document.getElementsByClassName("error-container")){
				elem.style.display = "block";
			}
			for(const elem of document.getElementsByClassName("error-message")){
				elem.textContent = err.reason
			}
		}
		async function copyLink(){
			await navigator.clipboard.writeText(document.getElementById("challengelink").textContent);
			for(const btn of document.getElementsByClassName("copybutton")){
				btn.textContent = "Copied"
			}
		}
	</script>
</head>
<body>
	<%- include('navheader'); %>
	<div style="display:none;" class="error-container">
		Disconnected:
		<div class="error-message"></div>
		(try reloading)
	</div>
	<br>
	Join link: <a id="challengelink" href="erm">erm</a> <button class="copybutton" onclick="copyLink()">Copy</button>
	<br>
	<br>
	Map: <a href="/creategame/<%=mapid%>"><b><%= mapname %></b></a>
	<br>
	<form class="room-content" autocomplete="off" id="rules-form">
		<span class="rules-form">
			<label for="public-box">Public</label><input type="checkbox" name="public" id="public-box">
			<br>
			<label for="max-player-box">Max players</label><input type="checkbox" id="max-player-box" name="max_player_box"><input type="number" min="2" value="2" name="max_player_count" id="max_player_count" >
		</span>
		<span class="rules-form">
			<select name="freedom">
				<option value="moving" selected>Moving</option>
				<option value="nm">No Moving</option>
				<option value="nmpz">No Moving, Panning or Zooming</option>
			</select>
			<br>
			<label for="time-limit-box">Time Limit </label><input type="checkbox" name="time_limit" id="time-limit-box"><input type="number" min="0" max="999" name="time_limit_minutes"> min <input type="number" min="0" max="59" name="time_limit_seconds"> sec 
			<br>
			<label for="time-limit-after-guess-box">Time Limit after guess </label><input type="checkbox" name="time_limit_after_guess" id="time-limit-after-guess-box"><input type="number" min="0" max="999" name="time_limit_minutes_after_guess"> min <input type="number" min="0" max="59" name="time_limit_seconds_after_guess"> sec 
			<br>
			<label for="max-health-input">Starting Health </label><input type="number" name="max_health" id="max-health-input" step="1000" min="0">
		</span>
		<span class="player-list-container">
			<label for="team-box">Teams</label><input type="checkbox" id="team-box" name="teams"><input type="number" min="2" name="team_count" id="team_count" value="2">
			<br>
			<b>Players</b>
			<ul class="player-list">
			</ul>
		</span>
	</form>
	<button disabled class="start-button">Start Duel</button>
	<script>
const path = window.location.pathname.split('/');
const duelid = path[path.length-1];
const url = "ws://"+window.location.host+"/duelroomsession/"+duelid;
const socket = new WebSocket(url);
socket.addEventListener("close", (evt)=>show_error(evt));
socket.addEventListener("message", msg => {
	console.log(msg.data)
	const data = JSON.parse(msg.data);
	const {type,info} = data;
	if(type == "update_rules"){
		update_rules(info);
	}
	else if(type == "update_player_list"){
		update_player_list(info);
	}
	else if(type == "start_duel"){
		window.location.replace("/duel/"+duelid);
	}
})
const form = document.getElementById("rules-form");
form.addEventListener('change',(evt)=>{
	const fd = Object.fromEntries((new FormData(form)).entries());
	const info = {};
	info.moving = (fd["freedom"]=="moving");
	info.panning = (info.zooming = (fd["freedom"] != "nmpz"));
	info.max_health = fd["max_health"]
	for(const suffix of ['','_after_guess']){
		info["time_limit"+suffix] = fd["time_limit"+suffix] 
			? 1000 * ((parseInt(fd["time_limit_minutes"+suffix])||0)*60+(parseInt(fd["time_limit_seconds"+suffix])||0)) 
			: null;
	}
	if(fd["teams"]){
		info.teams = {};
		for(const elem of document.getElementsByClassName("team-selector")){
			const {user} = elem.dataset;
			for(const team of elem.options){
				if(!team.value){
					continue;
				}
				info.teams[team.value] ??= [];
			}
			if(elem.value){
				info.teams[elem.value].push(user);
			}
		}
		const team_count = Math.max(2,document.getElementById("team_count").value);
		const team_name_set = new Set(Object.keys(info.teams));
		for(let i=1; Object.keys(info.teams).length<team_count; i++){
			const teamname = `Team ${i}`;
			if(!team_name_set.has(teamname)){
				info.teams[teamname] = []
			}
		}
		while(Object.keys(info.teams).length>team_count){
			delete info.teams[Object.keys(info.teams)[Object.keys(info.teams).length-1]]
		}
	}
	else{
		info.teams = null;
	}
	info.max_players = fd["max_player_box"] ? fd["max_player_count"] : null;
	info.public = fd["public"];
	socket.send(JSON.stringify({
		type:"update_rules",
		info
	}));
});
for(const btn of document.getElementsByClassName("start-button")){
	btn.addEventListener("click", ()=>{
		socket.send(JSON.stringify({type:"start_duel"}));
	});
}

window.addEventListener('load', () => {
	const elem = document.getElementById("challengelink");
	elem.textContent = window.location.href;
	elem.href = elem.textContent;
})
	</script>
</body>
</html>